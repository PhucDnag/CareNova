<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- ================= HEADER ================= -->
    <LinearLayout
        android:id="@+id/layout_header_top"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_media_previous"
            android:contentDescription="Back"
            app:tint="#000000"/>

        <TextView
            android:id="@+id/txt_page_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thông tin bệnh nhân"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp"
            />
    </LinearLayout>

    <!-- ================= SCROLL CONTENT ================= -->
    <ScrollView
        android:id="@+id/scroll_main"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/layout_header_top"
        app:layout_constraintBottom_toTopOf="@+id/layout_buttons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/layout_root"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ===== HEADER CARD ===== -->
            <LinearLayout
                android:id="@+id/layout_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:background="@android:drawable/dialog_holo_light_frame">

                <ImageView
                    android:id="@+id/img_avatar"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/avatar_benhnhan"
                    android:contentDescription="Avatar bệnh nhân"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txt_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bệnh nhân Nguyễn Thị A"
                        android:textSize="19sp"
                        android:textStyle="bold"
                        android:textColor="#000"/>

                    <TextView
                        android:id="@+id/txt_ma_bn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mã BN: BN001"
                        android:textSize="16sp"
                        android:textColor="#333"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ===== TITLE SECTION ===== -->
            <TextView
                android:id="@+id/txt_title_section"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thông tin cá nhân"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#000"
                android:layout_marginTop="18dp"/>

            <!-- ===== PERSONAL INFO ===== -->
            <TextView
                android:id="@+id/txt_ho_ten"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Họ và tên: Nguyễn Thị A"
                android:textSize="17sp"
                android:layout_marginTop="10dp"/>

            <TextView
                android:id="@+id/txt_gioi_tinh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giới tính: Nữ"
                android:textSize="17sp"
                android:layout_marginTop="6dp"/>

            <TextView
                android:id="@+id/txt_tuoi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tuổi: 23"
                android:textSize="17sp"
                android:layout_marginTop="6dp"/>

            <!-- ===== DIVIDER ===== -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DDDDDD"
                android:layout_marginTop="18dp"/>

            <!-- ===== STATUS INFO ===== -->
            <TextView
                android:id="@+id/txt_trang_thai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trạng thái: Đang điều trị"
                android:textSize="17sp"
                android:layout_marginTop="14dp"/>

            <TextView
                android:id="@+id/txt_last_visit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lần khám gần nhất: 30/01/2026"
                android:textSize="17sp"
                android:layout_marginTop="6dp"/>

            <TextView
                android:id="@+id/txt_bac_si"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bác sĩ phụ trách: BS. Minh"
                android:textSize="17sp"
                android:layout_marginTop="6dp"/>

            <!-- ===== ACTION ICON ===== -->
            <LinearLayout
                android:id="@+id/layout_action"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="28dp">

                <!-- BỆNH ÁN -->
                <LinearLayout
                    android:id="@+id/layout_benhan"
                    android:layout_width="130dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:src="@drawable/ic_hoso"
                        android:contentDescription="Bệnh án"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bệnh án"
                        android:textSize="16sp"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- PHÁC ĐỒ -->
                <LinearLayout
                    android:id="@+id/layout_phacdo"
                    android:layout_width="130dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:src="@drawable/ic_phacdo"
                        android:contentDescription="Phác đồ"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Phác đồ"
                        android:textSize="16sp"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- ================= BUTTONS ================= -->
    <LinearLayout
        android:id="@+id/layout_buttons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnThemBenhAn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Thêm Bệnh Án"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnThemPhacDo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Thêm Phác Đồ"
            android:layout_marginStart="8dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
