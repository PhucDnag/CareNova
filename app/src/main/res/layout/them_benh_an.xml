<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Back -->
    <ImageView
        android:id="@+id/btn_back"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:src="@android:drawable/ic_media_previous"
        android:contentDescription="@string/cd_back"
        app:tint="#000000"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Title -->
    <TextView
        android:id="@+id/txt_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="@string/add_medical_record_title"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#000"
        app:layout_constraintStart_toEndOf="@id/btn_back"
        app:layout_constraintTop_toTopOf="@id/btn_back"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Scroll -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/txt_title"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Info bệnh nhân -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:background="@android:drawable/dialog_holo_light_frame">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/avatar_benhnhan"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvPatientName"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/tvPatientInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/tvPatientCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <!-- Ngày khám -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">

                        <TextView
                            android:text="@string/visit_date"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <EditText
                            android:id="@+id/edtVisitDate"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:hint="@string/hint_visit_date"
                            android:background="@android:drawable/edit_text"/>
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>

            <!-- Nguyên nhân -->
            <TextView
                android:text="@string/visit_reason_title"
                android:textStyle="bold"
                android:layout_marginTop="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/edtReason"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="@string/hint_visit_reason"
                android:background="@android:drawable/edit_text"/>

            <!-- Trước điều trị -->
            <TextView
                android:text="@string/before_treatment_status"
                android:textStyle="bold"
                android:layout_marginTop="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/edtBeforeTreatment"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="@string/hint_before_treatment"
                android:background="@android:drawable/edit_text"/>

            <!-- Sau điều trị -->
            <TextView
                android:text="@string/after_treatment_status"
                android:textStyle="bold"
                android:layout_marginTop="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/edtAfterTreatment"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="@string/hint_after_treatment"
                android:background="@android:drawable/edit_text"/>

            <!-- Chẩn đoán -->
            <TextView
                android:text="@string/diagnosis"
                android:textStyle="bold"
                android:layout_marginTop="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/edtDiagnosis"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="@string/hint_diagnosis"
                android:background="@android:drawable/edit_text"/>

            <!-- Mô tả -->
            <TextView
                android:text="@string/description"
                android:textStyle="bold"
                android:layout_marginTop="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/edtDescription"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="@string/hint_description"
                android:background="@android:drawable/edit_text"/>

            <!-- Confirm -->
            <Button
                android:id="@+id/btn_xac_nhan"
                android:layout_width="180dp"
                android:layout_height="48dp"
                android:layout_marginTop="24dp"
                android:layout_gravity="center"
                android:text="@string/confirm_add"
                android:backgroundTint="#2196F3"
                android:textColor="#FFFFFF"/>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
